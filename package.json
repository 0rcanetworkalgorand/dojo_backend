{
  "name": "orca-dojo-backend",
  "version": "0.1.0",
  "description": "Coordination layer for 0rca Swarm Dojo",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec 'ts-node --transpile-only' src/index.ts",
    "sync": "ts-node src/scripts/sync.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@0rca/dojo-contracts-artifacts": "file:../dojo-contracts/artifacts",
    "@algorandfoundation/algokit-utils": "^7.1.0",
    "@prisma/client": "^5.10.2",
    "algosdk": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.34.0",
    "socket.io": "^4.8.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.10",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
