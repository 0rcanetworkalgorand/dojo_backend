generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums converted to Strings for SQLite compatibility
// LaneType: RESEARCH, CODE, DATA, OUTREACH
// AgentStatus: INACTIVE, ACTIVE, LISTED, SUSPENDED
// TaskState: CREATED, LOCKED, SUBMITTED, VERIFIED, SETTLED, SLASHED
// CommitmentStatus: ACTIVE, RELEASED_CLEAN, RELEASED_EARLY, EXPIRED
// RecipientRole: WORKER, COLLABORATOR, SENSEI, TREASURY

model Agent {
  id              String   @id @default(uuid())
  address         String   @unique
  senseiAddress   String
  lane            String   // Was LaneType
  status          String   // Was AgentStatus
  configHash      String
  tasksCompleted  BigInt   @default(0)
  tasksFailed     BigInt   @default(0)
  totalEarnedUsdc BigInt   @default(0)
  listingExpiry   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // relations
  tasks           Task[]   @relation("WorkerAgent")
  commitments     Commitment[]
  licenses        License[]  @relation("LicensedAgent")
  payouts         PayoutRecipient[]

  @@index([senseiAddress, lane, status])
}

model Task {
  id              String      @id // UUID generated by backend
  title           String?     // user-provided task title
  description     String?     // user-provided task description
  result          String?     // AI-generated output
  clientAddress   String
  workerAddress   String?     // set when agent accepts
  agentId         String?     // FK to agents.id
  lane            String      // Was LaneType
  bountyUsdc      BigInt      // microUSDC
  collateralUsdc  BigInt?     // microUSDC
  kiteHash        String?     // attribution hash from Kite AI
  state           String      // Was TaskState
  deadline        DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  settledAt       DateTime?

  // relations
  agent           Agent?      @relation("WorkerAgent", fields: [agentId], references: [id])
  payout          Payout?

  @@index([workerAddress, state, deadline])
}

model Commitment {
  id              String      @id @default(uuid())
  agentId         String      
  senseiAddress   String      
  stakeUsdc       BigInt      
  durationDays    Int               
  lockStart       DateTime    
  lockExpiry      DateTime    
  status          String      // Was CommitmentStatus
  penaltyUsdc     BigInt?           
  releasedAt      DateTime?         
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // relations
  agent           Agent       @relation(fields: [agentId], references: [id])
  licenses        License[]         

  @@index([senseiAddress, status, lockExpiry])
}

model License {
  id              String      @id @default(uuid())
  agentId         String      
  licenseeAddress String      
  commitmentId    String?     
  feeUsdc         BigInt      
  startedAt       DateTime    @default(now())
  expiresAt       DateTime?   
  isActive        Boolean     @default(true)

  // relations
  agent           Agent       @relation("LicensedAgent", fields: [agentId], references: [id])
  commitment      Commitment? @relation(fields: [commitmentId], references: [id])

  @@index([licenseeAddress, agentId, isActive])
}

model Payout {
  id              String      @id @default(uuid())
  taskId          String      @unique   
  totalUsdc       BigInt                
  platformFeeUsdc BigInt                
  algorandTxId    String                
  settledAt       DateTime    @default(now())

  // relations
  task            Task        @relation(fields: [taskId], references: [id])
  recipients      PayoutRecipient[]
}

model PayoutRecipient {
  id              String      @id @default(uuid())
  payoutId        String            
  recipientAddress String           
  agentId         String?           
  shareUsdc       BigInt            
  sharePercent    Int               
  role            String   // Was RecipientRole

  // relations
  payout          Payout      @relation(fields: [payoutId], references: [id])
  agent           Agent?      @relation(fields: [agentId], references: [id])

  @@index([recipientAddress, agentId])
}

model IndexerCursor {
  id              Int      @id @default(1)
  lastRound       BigInt   
  updatedAt       DateTime @updatedAt
}

model CommitmentCheckLog {
  id              String      @id @default(uuid())
  ranAt           DateTime    @default(now())
  commitmentsChecked Int               
  expiredFound    Int                  
  slashesTriggered Int                 
  errors          String?              
}
